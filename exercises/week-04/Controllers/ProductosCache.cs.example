using EcoBazaar.Api.Features.Catalog;
using Microsoft.AspNetCore.Mvc;

namespace EcoBazaar.Api.Controllers;

[ApiController]
[Route("api/productos")]
public sealed class ProductosController(IProductoService productoService)
    : ControllerBase
{
    [HttpGet]
    [ResponseCache(
        Duration = 60,
        Location = ResponseCacheLocation.Any,
        VaryByQueryKeys = new[] { "page", "pageSize", "search", "categoriaId", "sortBy", "sortDirection" })]
    [ProducesResponseType<ProductosPageResponse>(StatusCodes.Status200OK)]
    [ProducesResponseType<ProblemDetails>(StatusCodes.Status400BadRequest)]
    public async Task<ActionResult<ProductosPageResponse>> GetProductsAsync(
        [FromQuery] ProductoQueryParameters query,
        CancellationToken cancellationToken)
    {
        var page = await productoService.GetProductsAsync(query, cancellationToken);
        return Ok(page);
    }

    [HttpGet("{id:int}")]
    [ResponseCache(Duration = 60, Location = ResponseCacheLocation.Any)]
    [ProducesResponseType<ProductoResponseDto>(StatusCodes.Status200OK)]
    [ProducesResponseType<ProblemDetails>(StatusCodes.Status404NotFound)]
    public async Task<ActionResult<ProductoResponseDto>> GetProductAsync(
        int id,
        CancellationToken cancellationToken)
    {
        var product = await productoService.GetProductAsync(id, cancellationToken);
        return Ok(product);
    }
}
